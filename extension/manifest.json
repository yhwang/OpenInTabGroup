{
  "manifest_version": 3,
  "name": "Open in Tab Group",
  "version": "1.0.1",
  "description": "Open links directly into existing or new tab groups via right-click context menu",
  "author": "yhwang",
  "homepage_url": "https://github.com/yhwang/OpenInTabGroup",
  "permissions": [
    "contextMenus",
    "tabs",
    "tabGroups"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}